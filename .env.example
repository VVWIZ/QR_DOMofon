# .env.example — dev/walking skeleton (architecture.md §5).
# Скопируйте в .env: `cp .env.example .env`. Значения ниже — dev-дефолты для
# запуска на localhost. Секреты помечены «НЕ ДЛЯ ПРОД».

# --- HTTP / логирование ---
HTTP_ADDR=:8080
LOG_LEVEL=info

# --- PostgreSQL (dev: sslmode=disable; ПРОД: sslmode=require + TLS на сервере) ---
DATABASE_URL=postgres://domofon:domofon@localhost:5432/domofon?sslmode=disable

# --- Redis ---
REDIS_ADDR=localhost:6379

# --- MQTT (EMQX, dev: без TLS, anonymous auth — PROTOCOL.md §1, §7) ---
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=domofon-backend

# --- LiveKit (self-hosted, ws:// для браузера; токены выпускает только backend) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
# НЕ ДЛЯ ПРОД: dev-секрет LiveKit (совпадает с deploy/livekit/livekit.yaml)
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_chars

# --- Канонические фикстуры (architecture.md §5) ---
DEVICE_ID=66666666-6666-6666-6666-666666666666
DEVICE_SERIAL=EMU-001
APARTMENT_ID=33333333-3333-3333-3333-333333333333
ACCESS_POINT_PUBLIC_ID=55555555-5555-5555-5555-555555555555

# --- QR-подпись. Используется cmd/qrgen И backend-keyring (если QR_SECRET задан,
# он переопределяет секрет для QR_KID вместо БД qr_keys — §17.4). Пусто у backend
# → секрет из сида qr_keys. НЕ ДЛЯ ПРОД: dev-секрет; в проде — из KMS/Vault ---
QR_KID=dev1
QR_V=1
QR_SECRET=dev-qr-secret-change-me
VISITOR_BASE_URL=http://localhost:5173
